---
interface Props {
  transparent?: boolean;
}
const { transparent = false } = Astro.props;
---
<header class:list={["site-header", transparent && "site-header-transparent"]}>
  <a href="/" class="wordmark mono">SYMPATICA</a>
  <nav class="site-nav">
    <a href="/work">Work</a>
    <a href="/roster">Roster</a>
    <a href="/about">About</a>
    <a href="/contact">Contact</a>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px var(--gutter);
    background: var(--bg);
    border-bottom: 1px solid var(--rule);
  }
  .wordmark {
    font-family: var(--font-mono);
    font-size: var(--type-eyebrow);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 500;
  }
  .site-nav {
    display: flex;
    align-items: center;
    gap: var(--gap-lg);
    font-family: var(--font-sans);
    font-size: 16px;
    font-weight: 500;
    letter-spacing: -0.01em;
  }
  .site-nav a:hover { opacity: 1; color: var(--ink-muted); }

  /* Transparent variant: overlays the hero on the homepage */
  .site-header-transparent {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    background: transparent;
    border-bottom: 0;
    color: #fff;
  }
  .site-header-transparent .wordmark,
  .site-header-transparent .site-nav a {
    color: #fff;
    text-shadow: 0 1px 6px rgba(0,0,0,0.4);
  }
  .site-header-transparent .site-nav {
    font-size: 18px;
  }

  @media (max-width: 720px) {
    .site-header {
      flex-direction: column;
      align-items: stretch;
      gap: var(--gap-sm);
      padding: var(--gap-sm) var(--gutter);
    }
    .site-nav {
      gap: var(--gap-md);
      justify-content: space-between;
      flex-wrap: nowrap;
      font-size: 15px;
    }
    .site-header-transparent .site-nav { font-size: 16px; }
  }
</style>
